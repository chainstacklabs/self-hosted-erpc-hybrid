# Self-hosted Ethereum Hoodi node RPC, as reached by eRPC running on the same box.
# With Chainstack Self-Hosted (k3s), point this at the reth-rpc ClusterIP — it's routable
# from the host and survives disconnects (unlike `kubectl port-forward`). Find it with:
#   kubectl -n control-panel-deployments get svc | grep reth-rpc
SELF_HOSTED_RPC_URL=http://<RETH-RPC-CLUSTER-IP>:8545

# Chainstack Cloud Ethereum Hoodi ARCHIVE node HTTPS endpoint, including the auth key path.
CLOUD_RPC_URL=https://ethereum-hoodi.core.chainstack.com/REPLACE_WITH_KEY

# Base URLs the verification scripts hit. Run them on the box: eRPC's ports 4000/4001
# stay firewalled from the internet.
ERPC_BASE=http://localhost:4000/main/evm/560048
METRICS_BASE=http://localhost:4001/metrics
